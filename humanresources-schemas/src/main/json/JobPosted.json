{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/events/job-posted.schema.json",
    "title": "JobPosted",
    "description": "An event triggered when a new job listing is published.",
    "type": "object",
    "required": [
        "eventId",
        "timestamp",
        "jobId",
        "title",
        "company"
    ],
    "properties": {
        "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the event instance."
        },
        "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 timestamp of when the event occurred."
        },
        "jobId": {
            "type": "string",
            "description": "The unique identifier of the job in the source system."
        },
        "title": {
            "type": "string",
            "minLength": 5,
            "description": "The professional title of the job posting."
        },
        "company": {
            "type": "object",
            "required": [
                "id",
                "name"
            ],
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "location": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "On-site",
                        "Remote",
                        "Hybrid"
                    ]
                },
                "city": {
                    "type": "string"
                },
                "country": {
                    "type": "string"
                }
            }
        },
        "salary": {
            "type": "object",
            "properties": {
                "currency": {
                    "type": "string",
                    "pattern": "^[A-Z]{3}$"
                },
                "min": {
                    "type": "number",
                    "minimum": 0
                },
                "max": {
                    "type": "number",
                    "minimum": 0
                }
            }
        },
        "employmentType": {
            "type": "string",
            "enum": [
                "Full-time",
                "Part-time",
                "Contract",
                "Internship"
            ]
        }
    }
}